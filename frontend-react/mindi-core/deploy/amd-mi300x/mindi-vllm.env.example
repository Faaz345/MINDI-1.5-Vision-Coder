# Copy to /etc/mindigenous/mindi-vllm.env on the MI300X droplet.
# Do not commit the real API key or HF token.

MINDI_MODEL_PATH=/shared-docker/models/mindi-1.5
MINDI_SERVED_MODEL_NAME=mindi-1.5
MINDI_API_KEY=replace-with-openssl-rand-hex-32
MINDI_PORT=8000

# The AMD Developer Cloud vLLM image usually runs vLLM inside the rocm container.
VLLM_RUN_MODE=docker-exec
VLLM_CONTAINER=rocm

VLLM_DTYPE=bfloat16
VLLM_GPU_MEMORY_UTILIZATION=0.90
VLLM_MAX_MODEL_LEN=32768
VLLM_EXTRA_ARGS=--trust-remote-code

# Optional when loading from Hugging Face or another gated model source.
HF_TOKEN=
